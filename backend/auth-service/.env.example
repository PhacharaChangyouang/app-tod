PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_NAME=auth_db
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# OTP — Mock mode สำหรับ dev (ยังไม่ต่อ SMS gateway จริง)
OTP_MOCK_MODE=true
OTP_MOCK_CODE=123456
OTP_EXPIRES_IN_MINUTES=5
# ตอนต่อ SMS gateway จริง (Sprint 4) ค่อยเติม:
# SMS_PROVIDER=twilio
# SMS_API_KEY=
# SMS_API_SECRET=
# SMS_SENDER_ID=

# PIN
PIN_LENGTH=4

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
